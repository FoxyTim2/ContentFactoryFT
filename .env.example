# Telegram API credentials for reading source channels (https://my.telegram.org)
TG_API_ID=123456
TG_API_HASH=your_api_hash
TG_SESSION_NAME=content_factory_session

# Telegram bot token for sending processed posts
TG_BOT_TOKEN=123456:ABCDEF

# Destination channel/chat where the bot posts summaries
TG_TARGET_CHAT=@your_target_channel

# Comma-separated list of source channels to monitor
TG_SOURCE_CHANNELS=@source_channel_1,@source_channel_2

# Polling interval in seconds
POLL_INTERVAL_SECONDS=300

# Keep only messages newer than N hours (used when START_MODE=lookback)
LOOKBACK_HOURS=24

# Startup mode: now|lookback
# now      -> initialize cursors at latest messages and do not publish history
# lookback -> process messages from LOOKBACK_HOURS window
START_MODE=now

# Russia policy: review|drop
RUSSIA_POLICY=review

# Optional admin chat for moderation commands and review queue
# If empty and policy says review, bot will drop review-only messages
ADMIN_REVIEW_CHAT_ID=

# Optional OpenAI key. If empty, bot uses heuristic fallback processing
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Max size of published/review text
MAX_OUTPUT_CHARS=1200

# Local sqlite path for deduplication state and moderation queue
STATE_DB_PATH=state.db
